{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "rootDir": "."
  },
  "include": [
    "hardhat.config.ts",
    "scripts/**/*.ts",
    "typechain-types/**/*.ts"
  ]
}
