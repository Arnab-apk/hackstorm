# ===========================================
# CREDVAULT - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local and fill in the values
# See docs/DEMO-SETUP.md for detailed instructions

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# ISSUER CONFIGURATION
# ===========================================
# Generate with: pnpm generate:keys
ISSUER_PRIVATE_KEY=
ISSUER_PUBLIC_KEY=
ISSUER_DID=did:web:localhost

# ===========================================
# BLOCKCHAIN (Polygon Amoy Testnet)
# ===========================================
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_CHAIN_ID=80002

# Contract address (set after running: pnpm deploy:contracts)
CREDENTIAL_REGISTRY_CONTRACT=

# Deployer wallet private key (for contract deployment only)
# WARNING: Never commit this key to version control!
DEPLOYER_PRIVATE_KEY=

# ===========================================
# DATABASE (MongoDB Atlas)
# ===========================================
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/credvault?retryWrites=true&w=majority
MONGODB_DB_NAME=credvault

# ===========================================
# IPFS STORAGE (Pinata)
# ===========================================
# Get from: https://app.pinata.cloud/keys
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ===========================================
# ROLE ASSIGNMENT
# ===========================================
# Wallet addresses for role-based access control
# Users connect via MetaMask - role determined by address match
# - If address matches ISSUER_WALLET_ADDRESS -> Issuer role
# - If address matches VERIFIER_WALLET_ADDRESS -> Verifier role
# - Any other address -> Recipient (user) role
ISSUER_WALLET_ADDRESS=
VERIFIER_WALLET_ADDRESS=

# ===========================================
# SESSION / AUTH
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
SESSION_EXPIRY=7d
