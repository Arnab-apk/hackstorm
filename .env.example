# ===========================================
# DECENTRALIZED IDENTITY SYSTEM - ENV CONFIG
# ===========================================

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# ISSUER CONFIGURATION
# ===========================================

# Ed25519 key pair for credential signing (generate with: npm run generate:keys)
ISSUER_PRIVATE_KEY=
ISSUER_PUBLIC_KEY=
ISSUER_DID=did:web:your-app.vercel.app

# ===========================================
# BLOCKCHAIN (Polygon)
# ===========================================

# Polygon Amoy Testnet
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_CHAIN_ID=80002

# Contract addresses (set after deployment)
CREDENTIAL_REGISTRY_CONTRACT=

# Deployer wallet (for contract deployment only)
DEPLOYER_PRIVATE_KEY=

# ===========================================
# DATABASE (MongoDB)
# ===========================================

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/decentralized-identity?retryWrites=true&w=majority
MONGODB_DB_NAME=decentralized-identity

# ===========================================
# IPFS (Pinata)
# ===========================================

PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ===========================================
# ROLE ASSIGNMENT
# ===========================================

# Wallet addresses for role-based access control
# Users connect via MetaMask - their role is determined by matching their address
ISSUER_WALLET_ADDRESS=
VERIFIER_WALLET_ADDRESS=

# ===========================================
# SESSION
# ===========================================

JWT_SECRET=your-super-secret-jwt-key-min-32-chars
SESSION_EXPIRY=7d
